# ============================================================
# RAG Demo 配置文件
# ============================================================
# 使用方法：
#   1. 复制本文件为 config.env：cp config.env.example config.env
#   2. 在 config.env 中填入你的 API Key
#   3. config.env 已被 .gitignore 忽略，不会提交到仓库


# ------------------------------------------------------------
# 模型提供商（二选一）
# ------------------------------------------------------------
# openai_compatible — 兼容 OpenAI API 协议的云端服务
#                     支持: OpenAI / DeepSeek / 通义千问 / Kimi / 豆包 等
# ollama            — 本地部署，完全离线运行
MODEL_PROVIDER=openai_compatible


# ------------------------------------------------------------
# LLM 对话模型配置
# ------------------------------------------------------------
# 负责理解用户问题并生成回答
#
# 各服务商配置示例：
#   服务商      API 地址                                              模型名称
#   OpenAI     https://api.openai.com/v1                             gpt-4o-mini / gpt-4o
#   DeepSeek   https://api.deepseek.com/v1                           deepseek-chat / deepseek-reasoner
#   通义千问    https://dashscope.aliyuncs.com/compatible-mode/v1     qwen-turbo / qwen-plus / qwen-max
#   Kimi       https://api.moonshot.cn/v1                            moonshot-v1-8k / moonshot-v1-32k
#   豆包       https://ark.cn-beijing.volces.com/api/v3              ep-你的接入点ID（在火山方舟控制台获取）

LLM_API_KEY=your_api_key
LLM_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL_NAME=doubao-seed-2-0-pro-260215


# ------------------------------------------------------------
# Embedding 向量化模型配置
# ------------------------------------------------------------
# 负责将文本转为向量，用于相似度检索
# ⭐ 可以和 LLM 使用不同的服务商（例如 LLM 用豆包，Embedding 用 OpenAI）
# ⭐ API Key 和 Base URL 留空时，自动复用上面 LLM 的配置
#
# 各服务商配置示例：
#   服务商      API 地址                                              模型名称
#   OpenAI     https://api.openai.com/v1                             text-embedding-3-small / text-embedding-3-large
#   通义千问    https://dashscope.aliyuncs.com/compatible-mode/v1     text-embedding-v3
#   豆包       https://ark.cn-beijing.volces.com/api/v3              ep-你的接入点ID

EMBEDDING_API_KEY=your_api_key
EMBEDDING_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_MODEL_NAME=doubao-embedding-vision-251215


# ------------------------------------------------------------
# Ollama 本地部署配置（仅 MODEL_PROVIDER=ollama 时生效）
# ------------------------------------------------------------
# 需要先安装 Ollama 并拉取模型：
#   ollama pull qwen2              （对话模型）
#   ollama pull nomic-embed-text   （向量化模型）

OLLAMA_BASE_URL=http://localhost:11434


# ------------------------------------------------------------
# 文本分块参数
# ------------------------------------------------------------
# CHUNK_SIZE    — 每个文本块的最大字符数，越大上下文越完整，但检索精度可能下降
# CHUNK_OVERLAP — 相邻块之间的重叠字符数，避免语义在块边界处断裂

CHUNK_SIZE=500
CHUNK_OVERLAP=50


# ------------------------------------------------------------
# 检索参数
# ------------------------------------------------------------
# SEARCH_TOP_K — 每次检索返回的最相关文档块数量，越大召回越多但可能引入噪音

SEARCH_TOP_K=4
